{
  "name": "arthsight",
  "version": "0.1.0",
  "private": true,
  "author": "Neel Knight (https://github.com/neelknight)",
  "license": "UNLICENSED",
  "description": "Intelligent NAV tracking and fund insights platform",
  "keywords": [
    "webapp",
    "arthsight",
    "nav-tracker",
    "fund-insights",
    "mutual-funds",
    "portfolio-analysis",
    "finance",
    "investment-tracking",
    "nextjs"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint",
    "clean": "rimraf .next dist",
    "clean:all": "rimraf .next dist node_modules"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
